{
  "name": "silvervpn",
  "version": "0.1.0",
  "private": true,
  "description": "SilverVPN Linux desktop proxy client.",
  "main": "main.js",
  "productName": "SilverVPN",
  "scripts": {
    "cli": "node cli.js",
    "serve": "node cli.js serve",
    "doctor": "node cli.js doctor",
    "verify": "node scripts/verify.js",
    "verify:full": "node scripts/verify.js --require-subscription",
    "verify:real": "node scripts/verify.js --require-subscription --real-url 38DFF325-8AE6-40A3-A8CD-4774DFE711E2.url",
    "start": "electron .",
    "install:desktop": "./scripts/install.sh",
    "update:desktop": "./scripts/update.sh",
    "check": "node --check cli.js && node --check main.js && node --check preload.js && node --check renderer/app.js && node --check scripts/verify.js",
    "pack": "electron-builder --linux AppImage deb"
  },
  "devDependencies": {
    "electron": "12.2.3",
    "electron-builder": "^22.14.13"
  },
  "build": {
    "appId": "com.silver.vpn.linux",
    "productName": "SilverVPN",
    "files": [
      "main.js",
      "cli.js",
      "preload.js",
      "package.json",
      "renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      }
    ],
    "linux": {
      "category": "Network",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
